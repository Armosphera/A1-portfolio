{
  "title": "A1 HH-HY RBAC Bridge Metrics (macstudio dev)",
  "uid": "a1-hhhy-rbac-bridge",
  "version": 1,
  "schemaVersion": 38,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "a1",
    "hh-hy",
    "rbac",
    "bridge",
    "macstudio"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Bridge requests/sec by outcome",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(rbac_bridge_requests_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Allow / Deny ratio (last 1h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(rbac_bridge_requests_total{outcome=\"allowed\"}[1h])) / clamp_min(sum(rate(rbac_bridge_requests_total[1h])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests by role",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum by (role) (rate(rbac_bridge_requests_total[5m]))",
          "legendFormat": "role={{role}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Requests by required role",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum by (required) (rate(rbac_bridge_requests_total[5m]))",
          "legendFormat": "required={{required}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Bridge enabled status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "up{job=\"hh-hy-bridge\"}",
          "refId": "A"
        }
      ]
    }
  ]
}